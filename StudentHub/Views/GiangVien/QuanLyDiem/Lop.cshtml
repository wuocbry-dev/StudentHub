@model QuanLyDiemViewModel
@{ Layout = "~/Views/GiangVien/_GiangVienLayout.cshtml"; ViewData["Title"] = "Bảng điểm " + Model.LopHoc.MaLop; }
<div class="d-flex flex-wrap justify-content-between gap-2 mb-4"><div><a href="/GiangVien/QuanLyDiem" class="text-decoration-none"><i class="bi bi-arrow-left"></i> Quản lý điểm</a><h1 class="h3 mt-2 mb-1">Bảng điểm @Model.LopHoc.MaLop</h1><p class="text-muted mb-0">@Model.LopHoc.TenLop · @Model.LopHoc.MonHoc?.TenMonHoc</p></div><form action="/GiangVien/QuanLyDiem/DongBoChuyenCan" method="post" class="align-self-end">@Html.AntiForgeryToken()<input type="hidden" name="lopHocId" value="@Model.LopHoc.Id"><button class="btn btn-outline-success"><i class="bi bi-arrow-repeat"></i> Đồng bộ điểm chuyên cần</button></form></div>
<div class="alert alert-info"><i class="bi bi-calculator me-2"></i>Điểm tổng kết = 10% chuyên cần + 30% giữa kỳ + 60% cuối kỳ. Chỉ tính khi đã nhập đủ ba cột.</div>
<div class="card border-0 shadow-sm"><div class="card-body border-bottom"><form class="row g-2"><div class="col-md-5"><input name="search" value="@Model.Search" class="form-control" placeholder="Tìm mã hoặc tên sinh viên"></div><div class="col-auto"><button class="btn btn-dark">Tìm</button></div></form></div><div class="table-responsive"><table class="table align-middle mb-0 grade-table"><thead><tr><th>Mã sinh viên</th><th>Họ tên</th><th>Chuyên cần</th><th>Giữa kỳ</th><th>Cuối kỳ</th><th>Tổng kết</th><th>Xếp loại</th><th></th></tr></thead><tbody>
@if(!Model.DanhSach.Any()){<tr><td colspan="8" class="text-center text-muted py-5">Không có sinh viên.</td></tr>}else{@foreach(var x in Model.DanhSach){var formId="diem-"+x.DangKyHocId;<tr><td>@x.MaSinhVien</td><td><strong>@x.HoTen</strong></td><td><input type="number" form="@formId" name="diemChuyenCan" value="@x.DiemChuyenCan" min="0" max="10" step="0.01" class="form-control form-control-sm grade-input"></td><td><input type="number" form="@formId" name="diemGiuaKy" value="@x.DiemGiuaKy" min="0" max="10" step="0.01" class="form-control form-control-sm grade-input"></td><td><input type="number" form="@formId" name="diemCuoiKy" value="@x.DiemCuoiKy" min="0" max="10" step="0.01" class="form-control form-control-sm grade-input"></td><td><strong>@(x.DiemTongKet?.ToString("0.00") ?? "-")</strong></td><td><span class="badge text-bg-light">@x.XepLoai</span></td><td><form id="@formId" action="/GiangVien/QuanLyDiem/Luu" method="post">@Html.AntiForgeryToken()<input type="hidden" name="lopHocId" value="@Model.LopHoc.Id"><input type="hidden" name="dangKyHocId" value="@x.DangKyHocId"><button class="btn btn-sm btn-primary">Lưu</button></form></td></tr>}}
</tbody></table></div></div>
