@model LopChiTietViewModel
@{ Layout = "~/Views/GiangVien/_GiangVienLayout.cshtml"; ViewData["Title"] = Model.LopHoc.TenLop; }
<div class="mb-3"><a href="/GiangVien/LopCuaToi" class="text-decoration-none"><i class="bi bi-arrow-left"></i> Lớp của tôi</a></div>
<div class="class-hero mb-4"><div><span class="badge bg-white text-primary mb-2">@Model.LopHoc.MaLop</span><h1>@Model.LopHoc.TenLop</h1><p>@Model.LopHoc.MonHoc?.MaMonHoc - @Model.LopHoc.MonHoc?.TenMonHoc · @Model.LopHoc.HocKy - @Model.LopHoc.NamHoc</p></div><div class="d-flex flex-wrap gap-2"><a href="/GiangVien/PhienDiemDanh/TaoMoi?lopHocId=@Model.LopHoc.Id" class="btn btn-light"><i class="bi bi-qr-code"></i> Điểm danh</a><a href="/GiangVien/QuanLyDiem/Lop/@Model.LopHoc.Id" class="btn btn-outline-light"><i class="bi bi-clipboard-data"></i> Quản lý điểm</a></div></div>
<div class="row g-4 mb-4"><div class="col-xl-8"><div class="card border-0 shadow-sm"><div class="card-header bg-white py-3 d-flex flex-wrap justify-content-between gap-2"><strong>Danh sách sinh viên</strong><form><div class="input-group input-group-sm"><input type="hidden" name="id" value="@Model.LopHoc.Id"><input name="search" value="@Model.Search" class="form-control" placeholder="Mã hoặc tên sinh viên"><button class="btn btn-dark">Tìm</button></div></form></div><div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>Mã sinh viên</th><th>Họ tên</th><th>Có mặt</th><th>Đi muộn</th><th>Vắng</th><th>Có phép</th><th>Chuyên cần</th></tr></thead><tbody>
@if(!Model.SinhVien.Any()){<tr><td colspan="7" class="text-center text-muted py-5">Không có sinh viên.</td></tr>}else{@foreach(var x in Model.SinhVien){<tr><td>@x.MaSinhVien</td><td><strong>@x.HoTen</strong><div class="small text-muted">@x.Email</div></td><td>@x.CoMat</td><td>@x.DiMuon</td><td>@x.Vang</td><td>@x.CoPhep</td><td><div class="progress attendance-progress"><div class="progress-bar @(x.TyLeChuyenCan < 70 ? "bg-danger" : "bg-success")" style="width:@x.TyLeChuyenCan.ToString("0",System.Globalization.CultureInfo.InvariantCulture)%"></div></div><small>@x.TyLeChuyenCan.ToString("0.0")%</small></td></tr>}}
</tbody></table></div></div></div>
<div class="col-xl-4"><div class="card border-0 shadow-sm"><div class="card-header bg-white py-3 fw-semibold">Lịch học</div><div class="list-group list-group-flush">@if(!Model.LichHoc.Any()){<div class="text-muted text-center py-4">Chưa có lịch học.</div>}else{@foreach(var x in Model.LichHoc){<div class="list-group-item py-3"><strong>Thứ @x.ThuTrongTuan</strong><div>@x.GioBatDau.ToString(@"hh\:mm") - @x.GioKetThuc.ToString(@"hh\:mm")</div><small class="text-muted">@x.PhongHoc?.MaPhong - @x.PhongHoc?.TenPhong</small></div>}}</div></div></div></div>
