@model List<LopCuaToiItemViewModel>
@{ Layout = "~/Views/GiangVien/_GiangVienLayout.cshtml"; ViewData["Title"] = "Lớp của tôi"; }
<div class="d-flex flex-wrap justify-content-between gap-2 mb-4"><div><h1 class="h3 mb-1">Lớp của tôi</h1><p class="text-muted mb-0">Các lớp được phân công giảng dạy</p></div><a href="/GiangVien/PhienDiemDanh/TaoMoi" class="btn btn-primary align-self-start"><i class="bi bi-plus-lg"></i> Tạo phiên điểm danh</a></div>
<div class="card border-0 shadow-sm"><div class="card-body border-bottom"><form class="row g-2"><div class="col-md-6"><input name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm mã lớp, tên lớp, môn học..."></div><div class="col-auto"><button class="btn btn-dark">Tìm kiếm</button></div></form></div><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th>Mã lớp</th><th>Tên lớp</th><th>Môn học</th><th>Học kỳ</th><th>Sinh viên</th><th>Điểm danh</th><th></th></tr></thead><tbody>
@if(!Model.Any()){<tr><td colspan="7" class="text-center text-muted py-5">Chưa được phân công lớp học.</td></tr>}else{@foreach(var x in Model){<tr><td><strong>@x.LopHoc.MaLop</strong></td><td>@x.LopHoc.TenLop</td><td>@x.LopHoc.MonHoc?.MaMonHoc - @x.LopHoc.MonHoc?.TenMonHoc</td><td>@x.LopHoc.HocKy - @x.LopHoc.NamHoc</td><td>@x.SoSinhVien</td><td>@x.SoBuoiDiemDanh buổi</td><td class="text-end text-nowrap"><a href="/GiangVien/LopCuaToi/ChiTiet/@x.LopHoc.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a> <a href="/GiangVien/QuanLyDiem/Lop/@x.LopHoc.Id" class="btn btn-sm btn-outline-success">Nhập điểm</a></td></tr>}}
</tbody></table></div></div>
