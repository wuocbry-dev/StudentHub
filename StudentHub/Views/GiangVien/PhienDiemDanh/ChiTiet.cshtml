@model PhienDiemDanhChiTietViewModel
@using System.Text.Json
@{ Layout = "~/Views/GiangVien/_GiangVienLayout.cshtml"; ViewData["Title"] = "Phiên " + Model.Phien.MaPhien; }
<div class="d-flex flex-wrap justify-content-between gap-2 mb-4"><div><a href="/GiangVien/PhienDiemDanh" class="text-decoration-none"><i class="bi bi-arrow-left"></i> Danh sách phiên</a><h1 class="h3 mt-2 mb-1">@Model.Phien.LopHoc?.MaLop - @Model.Phien.LopHoc?.TenLop</h1><p class="text-muted mb-0">@Model.Phien.NgayDiemDanh.ToString("dd/MM/yyyy") · @Model.Phien.GioBatDau.ToString(@"hh\:mm") - @Model.Phien.GioKetThuc.ToString(@"hh\:mm")</p></div><div class="d-flex gap-2 align-self-end"><a href="#danhSachDiemDanh" class="btn btn-outline-primary"><i class="bi bi-people"></i> Xem điểm danh</a><form action="/GiangVien/PhienDiemDanh/DoiTrangThai/@Model.Phien.Id" method="post" data-confirm="@(Model.Phien.DangMo ? "Đóng phiên điểm danh này?" : "Mở phiên điểm danh này?")">@Html.AntiForgeryToken()<button id="sessionToggle" class="btn @(Model.Phien.DangMo ? "btn-danger" : "btn-success")"><i class="bi @(Model.Phien.DangMo ? "bi-lock" : "bi-unlock")"></i> @(Model.Phien.DangMo ? "Đóng phiên" : "Mở phiên")</button></form></div></div>
<div class="row g-4 mb-4"><div class="col-lg-5"><div class="card border-0 shadow-sm h-100"><div class="card-body text-center p-4"><div id="countdownPanel" class="countdown-panel mb-3"><div id="countdownLabel" class="small text-uppercase">Thời gian còn lại</div><div id="sessionCountdown" class="session-countdown">--:--:--</div></div><div class="d-flex justify-content-center mb-3"><div id="qrcode" class="qr-box"></div></div><div class="text-muted small text-uppercase">Mã phiên điểm danh</div><div class="session-code">@Model.Phien.MaPhien</div><span id="sessionStatus" class="badge @(Model.Phien.DangMo ? "text-bg-success" : "text-bg-secondary") mb-3">@(Model.Phien.DangMo ? "Đang mở" : "Đã đóng")</span><div><button id="copyCheckIn" type="button" class="btn btn-outline-primary btn-sm" data-copy="@Model.CheckInUrl"><i class="bi bi-clipboard"></i> Sao chép liên kết</button></div></div></div></div>
<div class="col-lg-7"><div class="card border-0 shadow-sm h-100"><div class="card-body p-4"><h2 class="h5">Hướng dẫn điểm danh</h2><ol class="text-muted lh-lg"><li>Sinh viên đăng nhập bằng tài khoản đã được Admin cấp.</li><li>Quét QR hoặc nhập mã <strong>@Model.Phien.MaPhien</strong>.</li><li>Hệ thống chỉ chấp nhận sinh viên có đăng ký lớp.</li><li>Check-in sau 15 phút được ghi nhận là đi muộn.</li></ol><div class="alert alert-info mb-0"><i class="bi bi-shield-check me-2"></i>Đóng phiên để ngăn mọi check-in mới.</div></div></div></div></div>
<div id="danhSachDiemDanh" class="card border-0 shadow-sm"><div class="card-header bg-white py-3 d-flex justify-content-between"><strong>Danh sách điểm danh</strong><span class="text-muted">@Model.DanhSach.Count sinh viên · tự cập nhật mỗi 5 giây</span></div><div class="table-responsive"><table id="attendanceTable" class="table align-middle mb-0"><thead><tr><th>Mã sinh viên</th><th>Họ tên</th><th>Check-in</th><th>Trạng thái</th><th>Ghi chú</th><th></th></tr></thead><tbody>
@if(!Model.DanhSach.Any()){<tr><td colspan="6" class="text-center text-muted py-5">Không có sinh viên trong phiên.</td></tr>}else{@foreach(var x in Model.DanhSach){var formId="diemdanh-"+x.Id;<tr data-attendance-id="@x.Id"><td>@x.SinhVien?.MaSinhVien</td><td>@x.SinhVien?.HoTen</td><td data-checkin>@(x.ThoiGianCheckIn?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td><td><select name="trangThai" form="@formId" class="form-select form-select-sm attendance-select" data-attendance-status>@foreach(var status in Enum.GetValues<TrangThaiDiemDanh>()){<option value="@status" selected="@(x.TrangThai == status)">@status</option>}</select></td><td><input name="ghiChu" form="@formId" value="@x.GhiChu" class="form-control form-control-sm" placeholder="Ghi chú" data-attendance-note></td><td class="text-end"><form id="@formId" action="/GiangVien/PhienDiemDanh/CapNhatDiemDanh" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@x.Id"><button class="btn btn-sm btn-outline-primary">Lưu</button></form></td></tr>}}
</tbody></table></div></div>
@section Scripts {<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script><script>document.addEventListener('DOMContentLoaded',()=>{renderAttendanceQr(@Html.Raw(JsonSerializer.Serialize(Model.CheckInUrl)));startAttendanceCountdown(@Model.BatDauUnixMs,@Model.KetThucUnixMs,@Model.ServerNowUnixMs,@Model.Phien.DangMo.ToString().ToLowerInvariant());startAttendanceRefresh('/GiangVien/PhienDiemDanh/TrangThai/@Model.Phien.Id');});</script>}
