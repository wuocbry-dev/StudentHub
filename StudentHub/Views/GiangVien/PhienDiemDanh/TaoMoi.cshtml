@model TaoPhienDiemDanhViewModel
@{ Layout = "~/Views/GiangVien/_GiangVienLayout.cshtml"; ViewData["Title"] = "Tạo phiên điểm danh"; var lop = ViewBag.LopHoc as List<LopHoc> ?? []; }
<div class="mb-3"><a href="/GiangVien/PhienDiemDanh" class="text-decoration-none"><i class="bi bi-arrow-left"></i> Phiên điểm danh</a></div>
<div class="row justify-content-center"><div class="col-xl-7"><div class="card border-0 shadow-sm"><div class="card-body p-4"><h1 class="h4 mb-4">Tạo phiên điểm danh mới</h1><form method="post"><div asp-validation-summary="ModelOnly" class="alert alert-danger"></div><div class="mb-3"><label asp-for="LopHocId" class="form-label">Lớp học</label><select asp-for="LopHocId" class="form-select"><option value="">-- Chọn lớp --</option>@foreach(var x in lop){<option value="@x.Id">@x.MaLop - @x.TenLop (@x.MonHoc?.TenMonHoc)</option>}</select><span asp-validation-for="LopHocId" class="text-danger"></span></div><div class="row g-3"><div class="col-md-12"><label asp-for="NgayDiemDanh" class="form-label">Ngày điểm danh</label><input asp-for="NgayDiemDanh" type="date" class="form-control"><span asp-validation-for="NgayDiemDanh" class="text-danger"></span></div><div class="col-md-6"><label asp-for="GioBatDau" class="form-label">Giờ bắt đầu</label><input asp-for="GioBatDau" type="time" class="form-control"></div><div class="col-md-6"><label asp-for="GioKetThuc" class="form-label">Giờ kết thúc</label><input asp-for="GioKetThuc" type="time" class="form-control"><span asp-validation-for="GioKetThuc" class="text-danger"></span></div></div><button class="btn btn-primary mt-4"><i class="bi bi-qr-code"></i> Tạo mã và QR</button></form></div></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
