@model List<PhienDiemDanh>
@{ Layout = "~/Views/GiangVien/_GiangVienLayout.cshtml"; ViewData["Title"] = "Phiên điểm danh"; var lop = ViewBag.LopHoc as List<LopHoc> ?? []; }
<div class="d-flex flex-wrap justify-content-between gap-2 mb-4"><div><h1 class="h3 mb-1">Phiên điểm danh</h1><p class="text-muted mb-0">Quản lý mã phiên và kết quả chuyên cần</p></div><a href="/GiangVien/PhienDiemDanh/TaoMoi" class="btn btn-primary align-self-start"><i class="bi bi-plus-lg"></i> Tạo phiên</a></div>
<div class="card border-0 shadow-sm"><div class="card-body border-bottom"><form class="row g-2"><div class="col-md-5"><select name="lopHocId" class="form-select"><option value="">Tất cả lớp</option>@foreach(var x in lop){<option value="@x.Id" selected="@(ViewBag.LopHocId == x.Id)">@x.MaLop - @x.TenLop</option>}</select></div><div class="col-auto"><button class="btn btn-dark">Lọc</button></div></form></div><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th>Ngày</th><th>Lớp học</th><th>Mã phiên</th><th>Thời gian</th><th>Trạng thái</th><th></th></tr></thead><tbody>
@if(!Model.Any()){<tr><td colspan="6" class="text-center text-muted py-5">Chưa có phiên điểm danh.</td></tr>}else{@foreach(var x in Model){<tr><td>@x.NgayDiemDanh.ToString("dd/MM/yyyy")</td><td><strong>@x.LopHoc?.MaLop</strong><div class="small text-muted">@x.LopHoc?.TenLop</div></td><td><span class="session-code-sm">@x.MaPhien</span></td><td>@x.GioBatDau.ToString(@"hh\:mm") - @x.GioKetThuc.ToString(@"hh\:mm")</td><td><span class="badge @(x.DangMo ? "text-bg-success" : "text-bg-secondary")">@(x.DangMo ? "Đang mở" : "Đã đóng")</span></td><td class="text-end"><a href="/GiangVien/PhienDiemDanh/ChiTiet/@x.Id" class="btn btn-sm btn-outline-primary">Xem phiên</a></td></tr>}}
</tbody></table></div></div>
