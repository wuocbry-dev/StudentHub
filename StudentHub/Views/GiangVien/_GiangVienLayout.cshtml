<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - SIMS Giảng viên</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/giangvien.css" asp-append-version="true" />
</head>
<body>
    <aside class="admin-sidebar lecturer-sidebar" id="sidebar">
        <a class="brand" href="/GiangVien/Dashboard"><i class="bi bi-mortarboard-fill"></i> SIMS</a>
        <div class="small text-uppercase text-white-50 px-3 mt-3 mb-2">Cổng giảng viên</div>
        <nav class="nav flex-column">
            <a class="nav-link" href="/GiangVien/Dashboard"><i class="bi bi-grid"></i> Dashboard</a>
            <a class="nav-link" href="/GiangVien/LopCuaToi"><i class="bi bi-journal-text"></i> Lớp của tôi</a>
            <a class="nav-link" href="/GiangVien/PhienDiemDanh"><i class="bi bi-qr-code-scan"></i> Phiên điểm danh</a>
            <a class="nav-link" href="/GiangVien/QuanLyDiem"><i class="bi bi-clipboard-data"></i> Quản lý điểm</a>
        </nav>
    </aside>
    <main class="admin-main">
        <nav class="navbar navbar-expand bg-white border-bottom sticky-top px-3">
            <button class="btn btn-light d-lg-none" id="sidebarToggle"><i class="bi bi-list"></i></button>
            <span class="ms-3 text-muted d-none d-md-inline">Hệ thống quản lý sinh viên</span>
            <div class="ms-auto d-flex align-items-center gap-3">
                <span><i class="bi bi-person-circle me-1"></i> @User.Identity?.Name</span>
                <form action="/TaiKhoan/DangXuat" method="post">@Html.AntiForgeryToken()<button class="btn btn-outline-danger btn-sm"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button></form>
            </div>
        </nav>
        <div class="container-fluid p-3 p-lg-4">
            @if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button class="btn-close" data-bs-dismiss="alert"></button></div> }
            @if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]<button class="btn-close" data-bs-dismiss="alert"></button></div> }
            @RenderBody()
        </div>
    </main>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/giangvien.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", false)
</body>
</html>
