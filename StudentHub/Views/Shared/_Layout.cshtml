<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - SIMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand sims-brand" asp-controller="Home" asp-action="Index"><span><i class="bi bi-mortarboard-fill"></i></span> SIMS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Mở menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin")) { <li class="nav-item"><a class="btn btn-primary" href="/Admin/Dashboard">Trang quản trị</a></li> }
                            @if (User.IsInRole("GiangVien")) { <li class="nav-item"><a class="btn btn-primary" href="/GiangVien/Dashboard">Cổng giảng viên</a></li> }
                            @if (User.IsInRole("SinhVien")) { <li class="nav-item"><a class="btn btn-primary" href="/CheckIn">Điểm danh</a></li> }
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="TaiKhoan" asp-action="DangNhap">Đăng nhập</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main>@RenderBody()</main>
    <footer class="site-footer">
        <div class="container d-flex flex-wrap justify-content-between gap-2">
            <span>© 2026 SIMS - Hệ thống quản lý sinh viên</span>
            <span>StudentHub</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
