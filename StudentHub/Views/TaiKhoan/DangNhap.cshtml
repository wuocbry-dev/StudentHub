@model StudentHub.Models.DangNhapViewModel
@{ ViewData["Title"] = "Đăng nhập"; Layout = null; }
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Đăng nhập - SIMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
</head>
<body class="login-page">
    <main class="login-card card border-0">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <a href="/" class="login-logo text-decoration-none">SIMS</a>
                <h1 class="h4 mt-3 mb-2 fw-bold">Đăng nhập hệ thống</h1>
                <p class="text-muted mb-0">Sử dụng tài khoản do nhà trường cấp</p>
            </div>
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <div class="mb-3">
                    <label asp-for="TenDangNhap" class="form-label"></label>
                    <input asp-for="TenDangNhap" class="form-control form-control-lg" autofocus>
                    <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="MatKhau" class="form-label"></label>
                    <input asp-for="MatKhau" class="form-control form-control-lg">
                    <span asp-validation-for="MatKhau" class="text-danger small"></span>
                </div>
                <div class="form-check mb-4">
                    <input asp-for="GhiNho" class="form-check-input">
                    <label asp-for="GhiNho" class="form-check-label">Ghi nhớ đăng nhập</label>
                </div>
                <button class="btn btn-primary btn-lg w-100"><i class="bi bi-box-arrow-in-right"></i> Đăng nhập</button>
                <div class="text-center mt-3"><a href="/">Quay về trang chủ</a></div>
            </form>
        </div>
    </main>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
