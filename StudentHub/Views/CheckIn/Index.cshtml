@model CheckInViewModel
@{ ViewData["Title"] = "Check-in"; Layout = "~/Views/Shared/_SinhVienLayout.cshtml"; }
<div class="student-checkin"><div class="checkin-card card border-0 shadow-sm"><div class="card-body p-4 p-md-5 text-center"><div class="checkin-logo"><i class="bi bi-qr-code-scan"></i></div><h1 class="h4 mt-3">Check-in điểm danh</h1><p class="text-muted">Nhập mã phiên hoặc mở đường dẫn QR do giảng viên cung cấp.</p>
@if(!string.IsNullOrWhiteSpace(Model.Token) && Model.ThongBao == null){<div class="alert alert-info text-start"><i class="bi bi-qr-code me-2"></i>Đã nhận QR token. Bấm xác nhận để check-in.</div>}
@if(!Model.ThanhCong){<form method="post" class="text-start" id="studentCheckInForm"><input asp-for="Token" type="hidden"><div class="mb-3"><label asp-for="MaPhien" class="form-label">Mã phiên 6 ký tự</label><input asp-for="MaPhien" class="form-control form-control-lg text-uppercase text-center session-input" placeholder="ABC123" maxlength="6" autocomplete="off" disabled="@(!string.IsNullOrWhiteSpace(Model.Token))"><span asp-validation-for="MaPhien" class="text-danger"></span></div><button class="btn btn-primary btn-lg w-100"><i class="bi bi-check2-circle me-1"></i>Xác nhận check-in</button></form>}
else{<div class="checkin-success-mark"><i class="bi bi-check-lg"></i></div>}
<a href="/SinhVien/Dashboard" class="btn btn-link mt-3">Về Dashboard</a></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> @if(Model.ThongBao != null){<script>showStudentCheckInAlert(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ThanhCong)),@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ThongBao)));</script>} }
