@model CheckInViewModel
@{ ViewData["Title"] = "Check-in"; Layout = "~/Views/Shared/_SinhVienLayout.cshtml"; }
<div class="student-checkin"><div class="checkin-card card border-0 shadow-sm"><div class="card-body p-4 p-md-5 text-center"><div class="checkin-logo"><i class="bi bi-qr-code-scan"></i></div><h1 class="h4 mt-3">Điểm danh lớp học</h1><p class="text-muted">Nhập mã phiên được cung cấp bởi giảng viên.</p>
@if(Model.ThongBao != null){<div class="alert @(Model.ThanhCong ? "alert-success" : "alert-danger")">@Model.ThongBao</div>}
@if(!Model.ThanhCong){<form method="post" class="text-start"><input asp-for="Token" type="hidden"><div class="mb-3"><label asp-for="MaPhien" class="form-label">Mã phiên 6 ký tự</label><input asp-for="MaPhien" class="form-control form-control-lg text-uppercase text-center session-input" placeholder="ABC123" maxlength="6"><span asp-validation-for="MaPhien" class="text-danger"></span></div><button class="btn btn-primary btn-lg w-100">Xác nhận điểm danh</button></form>}
<a href="/SinhVien/Dashboard" class="btn btn-link mt-3">Về Dashboard</a></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
