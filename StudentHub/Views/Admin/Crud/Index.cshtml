@model StudentHub.Models.CrudPageViewModel
@using System.Reflection
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = Model.Title;
    var adminBaseUrl = "/Admin/" + ViewContext.RouteData.Values["controller"];
    string PageUrl(int page) => $"{adminBaseUrl}?page={page}&search={Uri.EscapeDataString(Model.Search)}";
    var columns = StudentHub.Models.AdminUiMetadata.GetListColumns(Model.EntityType);
    string Show(object? value) {
        if (value == null) return "-";
        if (value is DateTime d) return d.ToString("dd/MM/yyyy HH:mm");
        if (value is TimeSpan t) return t.ToString(@"hh\:mm");
        var type = value.GetType();
        if (type.IsClass && type != typeof(string)) {
            var code = type.GetProperties().FirstOrDefault(x => x.Name.StartsWith("Ma"))?.GetValue(value);
            var name = type.GetProperty("Ten" + type.Name)?.GetValue(value) ?? type.GetProperty("HoTen")?.GetValue(value) ?? type.GetProperty("TenPhong")?.GetValue(value) ?? type.GetProperty("TenLop")?.GetValue(value);
            return string.Join(" - ", new[] { code, name }.Where(x => x != null));
        }
        return value.ToString() ?? "-";
    }
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1 fw-bold">Quản lý @Model.Title.ToLower()</h1>
        <div class="text-muted">Tra cứu và cập nhật dữ liệu hệ thống</div>
    </div>
    <a href="@(adminBaseUrl + "/Create")" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm mới</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body border-bottom">
        <form action="@adminBaseUrl" method="get" class="row g-2">
            <div class="col-sm-8 col-lg-5">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input name="search" value="@Model.Search" class="form-control" placeholder="Tìm kiếm..." />
                </div>
            </div>
            <div class="col-auto"><button class="btn btn-dark">Tìm kiếm</button></div>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <div class="col-auto"><a href="@adminBaseUrl" class="btn btn-light">Xóa lọc</a></div>
            }
        </form>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>#</th>@foreach (var column in columns) { <th>@column.Label</th> }<th class="text-end">Thao tác</th></tr></thead>
            <tbody>
            @if (!Model.Items.Any())
            {
                <tr><td colspan="@(columns.Count + 2)" class="text-center py-5 text-muted">Chưa có dữ liệu.</td></tr>
            }
            else
            {
                @foreach (var item in Model.Items)
                {
                    var id = item.GetType().GetProperty("Id")?.GetValue(item);
                    <tr>
                        <td>@id</td>
                        @foreach (var column in columns) { <td>@Show(StudentHub.Models.AdminUiMetadata.GetValue(item, column.Path))</td> }
                        <td class="text-end text-nowrap">
                            <a href="@(adminBaseUrl + "/Edit/" + id)" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form action="@(adminBaseUrl + "/Delete/" + id)" method="post" class="d-inline delete-form">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <small class="text-muted">Trang @Model.Page / @Model.TotalPages</small>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")"><a class="page-link" href="@PageUrl(Model.Page - 1)">Trước</a></li>
                <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")"><a class="page-link" href="@PageUrl(Model.Page + 1)">Sau</a></li>
            </ul>
        </nav>
    </div>
</div>
