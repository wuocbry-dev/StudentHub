@model ImportResultViewModel
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Kết quả import";
}
@section Styles {
    <link rel="stylesheet" href="~/css/nhapdulieu.css" asp-append-version="true" />
}

<div class="nhap-result @(Model.ThanhCong ? "is-success" : "is-error")">
    <i class="bi @(Model.ThanhCong ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
    <h1>@(Model.ThanhCong ? "Import thành công" : "Import chưa thành công")</h1>
    <p>@(Model.LichSu.GhiChu ?? "Không có ghi chú.")</p>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4"><span class="text-muted d-block">Tên file</span><strong>@Model.LichSu.TenFile</strong></div>
            <div class="col-md-4"><span class="text-muted d-block">Loại dữ liệu</span><strong>@Model.LichSu.LoaiDuLieu</strong></div>
            <div class="col-md-4"><span class="text-muted d-block">Người import</span><strong>@Model.LichSu.TaiKhoan?.HoTen</strong></div>
            <div class="col-md-3"><span class="text-muted d-block">Tổng dòng</span><strong>@Model.LichSu.TongSoDong</strong></div>
            <div class="col-md-3"><span class="text-muted d-block">Đã nhập</span><strong>@Model.LichSu.SoDongDaNhap</strong></div>
            <div class="col-md-3"><span class="text-muted d-block">Dòng lỗi</span><strong>@Model.LichSu.SoDongLoi</strong></div>
            <div class="col-md-3"><span class="text-muted d-block">Thời gian</span><strong>@Model.LichSu.NgayNhap.ToString("dd/MM/yyyy HH:mm")</strong></div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-4">
            <a class="btn btn-primary" href="/Admin/NhapDuLieu"><i class="bi bi-upload"></i> Import file khác</a>
            <a class="btn btn-light" href="/Admin/NhapDuLieu/LichSu"><i class="bi bi-clock-history"></i> Xem lịch sử</a>
            <a class="btn btn-outline-primary" href="/Admin/NhapDuLieu/ChiTiet/@Model.LichSu.Id"><i class="bi bi-list-check"></i> Xem chi tiết</a>
            @if (Model.LichSu.SoDongLoi > 0)
            {
                <a class="btn btn-outline-secondary" href="/Admin/NhapDuLieu/TaiFileLoi/@Model.LichSu.Id" data-no-ajax="true" download><i class="bi bi-download"></i> Tải file lỗi</a>
            }
        </div>
    </div>
</div>
