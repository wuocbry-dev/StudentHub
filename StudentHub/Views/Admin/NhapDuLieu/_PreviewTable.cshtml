@model ImportPreviewViewModel

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 nhap-preview-table">
            <thead><tr><th>STT</th><th>Số dòng</th><th>Nội dung dữ liệu</th><th>Trạng thái</th><th>Ghi chú lỗi</th></tr></thead>
            <tbody>
            @if (!Model.Rows.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-5">Không có dữ liệu preview.</td></tr>
            }
            else
            {
                var index = 1;
                foreach (var row in Model.Rows)
                {
                    <tr class="@(row.HopLe ? "nhap-row-valid" : "nhap-row-error")">
                        <td>@index</td>
                        <td>@row.SoDong</td>
                        <td>
                            <div class="nhap-json-grid">
                                @foreach (var item in row.NoiDung)
                                {
                                    <span><strong>@item.Key</strong>@item.Value</span>
                                }
                            </div>
                        </td>
                        <td><span class="badge @(row.HopLe ? "text-bg-success" : "text-bg-danger")">@(row.HopLe ? "HopLe" : "Loi")</span></td>
                        <td class="small">@(!string.IsNullOrWhiteSpace(row.NoiDungLoi) ? row.NoiDungLoi : "-")</td>
                    </tr>
                    index++;
                }
            }
            </tbody>
        </table>
    </div>
</div>
