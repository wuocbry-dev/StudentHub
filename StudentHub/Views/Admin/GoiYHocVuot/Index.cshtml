@model AdminGoiYHocVuotPageViewModel
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Gợi ý học vượt";
}
@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/hocvuot.css" asp-append-version="true" />
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Gợi ý học vượt</h1>
        <div class="text-muted">Quản lý và tạo lại gợi ý học vượt bằng logic theo luật.</div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Khoa</label>
                <select name="khoaId" class="form-select">
                    <option value="">Tất cả</option>
                    @foreach (var khoa in Model.KhoaOptions)
                    {
                        <option value="@khoa.Id" selected="@(khoa.Id == Model.KhoaId)">@khoa.MaKhoa - @khoa.TenKhoa</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Sinh viên</label>
                <select name="sinhVienId" class="form-select">
                    <option value="">Tất cả</option>
                    @foreach (var sv in Model.SinhVienOptions)
                    {
                        <option value="@sv.Id" selected="@(sv.Id == Model.SinhVienId)">@sv.MaSinhVien - @sv.HoTen</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Học kỳ - Năm học</label>
                <select class="form-select" name="hocKyNamHoc" onchange="this.form.querySelector('[name=hocKy]').value=this.selectedOptions[0].dataset.hocky || '';this.form.querySelector('[name=namHoc]').value=this.selectedOptions[0].dataset.namhoc || ''">
                    <option value="" data-hocky="" data-namhoc="">Tất cả</option>
                    @foreach (var option in Model.HocKyOptions)
                    {
                        <option data-hocky="@option.HocKy" data-namhoc="@option.NamHoc" selected="@(option.HocKy == Model.HocKy && option.NamHoc == Model.NamHoc)">@option.Label</option>
                    }
                </select>
                <input type="hidden" name="hocKy" value="@Model.HocKy" />
                <input type="hidden" name="namHoc" value="@Model.NamHoc" />
            </div>
            <div class="col-auto"><button class="btn btn-dark"><i class="bi bi-funnel"></i> Lọc</button></div>
        </form>
        <form action="/Admin/GoiYHocVuot/TaoLai" method="post" class="mt-3" data-hocvuot-confirm="Tạo lại gợi ý học vượt theo bộ lọc hiện tại?">
            @Html.AntiForgeryToken()
            <input type="hidden" name="khoaId" value="@Model.KhoaId" />
            <input type="hidden" name="sinhVienId" value="@Model.SinhVienId" />
            <input type="hidden" name="hocKy" value="@Model.HocKy" />
            <input type="hidden" name="namHoc" value="@Model.NamHoc" />
            <button class="btn btn-primary" data-hocvuot-loading><i class="bi bi-arrow-repeat"></i> Tạo lại gợi ý</button>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="goiYHocVuotTable">
            <thead><tr><th>Mã sinh viên</th><th>Họ tên</th><th>Môn học được gợi ý</th><th>Lớp học</th><th>Điểm phù hợp</th><th>Mức độ</th><th>Lý do</th><th>Trạng thái</th><th>Ngày tạo</th></tr></thead>
            <tbody>
            @if (Model.GoiY.Count == 0)
            {
                <tr><td colspan="9" class="text-center text-muted py-5">Chưa có gợi ý học vượt.</td></tr>
            }
            else
            {
                @foreach (var item in Model.GoiY)
                {
                    <tr>
                        <td><strong>@item.MaSinhVien</strong><small class="d-block text-muted">@item.TenKhoa</small></td>
                        <td>@item.HoTenSinhVien</td>
                        <td><strong>@item.MaMonHoc</strong><small class="d-block text-muted">@item.TenMonHoc</small></td>
                        <td><span class="class-code">@item.MaLop</span><small class="d-block text-muted">@item.HocKyGoiY - @item.NamHocGoiY</small></td>
                        <td><div class="progress hocvuot-score-progress"><div class="progress-bar" style="width:@((int)item.DiemPhuHop)%">@item.DiemPhuHop.ToString("0.#")</div></div></td>
                        <td><span class="badge hocvuot-prereq-badge @MucDoBadge(item.MucDoGoiY)">@MucDoText(item.MucDoGoiY)</span></td>
                        <td class="small">@item.LyDoGoiY</td>
                        <td><span class="badge hocvuot-prereq-badge text-bg-secondary">@TrangThaiText(item.TrangThai)</span></td>
                        <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string MucDoBadge(MucDoGoiY value) => value switch
    {
        MucDoGoiY.RatPhuHop => "text-bg-success",
        MucDoGoiY.PhuHop => "text-bg-primary",
        MucDoGoiY.CanCanNhac => "text-bg-warning",
        _ => "text-bg-danger"
    };

    string MucDoText(MucDoGoiY value) => value switch
    {
        MucDoGoiY.RatPhuHop => "Rất phù hợp",
        MucDoGoiY.PhuHop => "Phù hợp",
        MucDoGoiY.CanCanNhac => "Cần cân nhắc",
        MucDoGoiY.KhongPhuHop => "Không phù hợp",
        _ => value.ToString()
    };

    string TrangThaiText(TrangThaiGoiY value) => value switch
    {
        TrangThaiGoiY.Moi => "Mới",
        TrangThaiGoiY.DaXem => "Đã xem",
        TrangThaiGoiY.DaDangKy => "Đã đăng ký",
        TrangThaiGoiY.DaBoQua => "Đã bỏ qua",
        TrangThaiGoiY.HetHan => "Hết hạn",
        _ => value.ToString()
    };
}

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/hocvuot.js" asp-append-version="true"></script>
}
