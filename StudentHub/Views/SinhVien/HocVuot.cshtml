@model SinhVienHocVuotViewModel
@{
    Layout = "~/Views/Shared/_SinhVienLayout.cshtml";
    ViewData["Title"] = "Học vượt";
}

@section Styles {
    <link rel="stylesheet" href="~/css/hocvuot.css" asp-append-version="true" />
}

<div class="page-heading">
    <div>
        <span class="page-eyebrow">GIỚI HẠN HỌC VƯỢT</span>
        <h1>Học vượt tối đa 5 môn</h1>
        <p>Theo dõi số môn học vượt đã đăng ký trong từng học kỳ và năm học.</p>
    </div>
</div>

<section class="student-panel hocvuot-limit-panel mb-4" data-hocvuot-limit data-hocvuot-full="@Model.DaDatGioiHan.ToString().ToLowerInvariant()">
    <div class="student-panel-header">
        <div>
            <h2>Trạng thái học vượt</h2>
            <p>@Model.HocKy - @Model.NamHoc</p>
        </div>
        <span class="hocvuot-status-badge @(Model.DaDatGioiHan ? "is-full" : Model.SoMonHocVuotDaDangKy >= 4 ? "is-warning" : "is-safe")">
            @Model.SoMonHocVuotDaDangKy/@Model.SoMonHocVuotToiDa
        </span>
    </div>
    <div class="hocvuot-limit-body">
        <form method="get" class="row g-3 align-items-end mb-4">
            <div class="col-md-5">
                <label class="form-label">Học kỳ - Năm học</label>
                <select class="form-select" name="hocKyNamHoc" onchange="this.form.querySelector('[name=hocKy]').value=this.selectedOptions[0].dataset.hocky;this.form.querySelector('[name=namHoc]').value=this.selectedOptions[0].dataset.namhoc">
                    @foreach (var option in Model.HocKyOptions)
                    {
                        <option data-hocky="@option.HocKy" data-namhoc="@option.NamHoc" selected="@(option.HocKy == Model.HocKy && option.NamHoc == Model.NamHoc)">
                            @option.Label
                        </option>
                    }
                </select>
                <input type="hidden" name="hocKy" value="@Model.HocKy" />
                <input type="hidden" name="namHoc" value="@Model.NamHoc" />
            </div>
            <div class="col-md-auto">
                <button class="btn btn-primary"><i class="bi bi-funnel"></i> Lọc</button>
            </div>
        </form>

        <div class="row g-3">
            <div class="col-lg-4">
                <div class="hocvuot-meter">
                    <small>Môn học vượt đã đăng ký</small>
                    <strong>@Model.SoMonHocVuotDaDangKy/@Model.SoMonHocVuotToiDa</strong>
                    <span>Còn có thể đăng ký thêm @Model.SoMonConLai môn.</span>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="hocvuot-progress-card">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tỷ lệ sử dụng giới hạn</span>
                        <strong>@Model.PhanTram%</strong>
                    </div>
                    <div class="progress">
                        <div class="progress-bar @Model.ProgressClass" role="progressbar" style="width:@Model.PhanTram%" aria-valuenow="@Model.PhanTram" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    @if (Model.DaDatGioiHan)
                    {
                        <div class="alert alert-danger mt-3 mb-0"><i class="bi bi-exclamation-triangle"></i> Bạn đã đạt giới hạn @Model.SoMonHocVuotToiDa môn học vượt trong học kỳ này.</div>
                    }
                    else if (Model.SoMonHocVuotDaDangKy >= 4)
                    {
                        <div class="alert alert-warning mt-3 mb-0"><i class="bi bi-exclamation-circle"></i> Bạn gần đạt giới hạn học vượt.</div>
                    }
                </div>
            </div>
        </div>

        <button type="button" class="btn mt-4 @(Model.DaDatGioiHan ? "btn-secondary" : "btn-outline-primary")" disabled="@Model.DaDatGioiHan" data-hocvuot-register data-hocvuot-list-url="/SinhVien/HocVuot/LayDanhSachLopHocVuot" data-hocvuot-post-url="/SinhVien/HocVuot/DangKy" data-hocvuot-cancel-url="/SinhVien/HocVuot/HuyDangKy" data-hocvuot-reregister-url="/SinhVien/HocVuot/DangKyLai" data-hocvuot-hocky="@Model.HocKy" data-hocvuot-namhoc="@Model.NamHoc">
            <i class="bi bi-plus-circle"></i> Đăng ký học vượt
        </button>
        @Html.AntiForgeryToken()
    </div>
</section>

<div class="modal fade hocvuot-register-modal" id="hocVuotRegisterModal" tabindex="-1" aria-labelledby="hocVuotRegisterModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h2 class="modal-title fs-5" id="hocVuotRegisterModalLabel">Đăng ký học vượt</h2>
                    <p class="mb-0 text-muted small">Chọn lớp thuộc khoa của bạn trong @Model.HocKy - @Model.NamHoc.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 align-items-end mb-3">
                    <div class="col-md-3">
                        <label class="form-label">Học kỳ</label>
                        <select class="form-select" data-hocvuot-modal-hocky>
                            @foreach (var hocKyOption in Model.HocKyOptions.Select(x => x.HocKy).Distinct())
                            {
                                <option value="@hocKyOption" selected="@(hocKyOption == Model.HocKy)">@hocKyOption</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Năm học</label>
                        <select class="form-select" data-hocvuot-modal-namhoc>
                            @foreach (var namHocOption in Model.HocKyOptions.Select(x => x.NamHoc).Distinct())
                            {
                                <option value="@namHocOption" selected="@(namHocOption == Model.NamHoc)">@namHocOption</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Tìm kiếm môn học</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input class="form-control" placeholder="Nhập mã lớp, mã môn hoặc tên môn" data-hocvuot-search />
                        </div>
                    </div>
                </div>
                <div class="hocvuot-modal-loading" data-hocvuot-loading hidden>
                    <span class="spinner-border text-primary"></span>
                    <strong>Đang tải danh sách lớp học vượt...</strong>
                </div>
                <div class="student-empty compact" data-hocvuot-empty hidden>
                    <i class="bi bi-journal-x"></i>
                    <strong>Không có lớp phù hợp trong học kỳ này.</strong>
                </div>
                <div class="hocvuot-class-list" data-hocvuot-class-list></div>
            </div>
        </div>
    </div>
</div>

<section class="student-panel">
    <div class="student-panel-header">
        <div>
            <h2>Danh sách môn học vượt</h2>
            <p>Các đăng ký đang được tính vào giới hạn hiện tại, gồm cả môn đã hủy để có thể đăng ký lại khi còn hạn.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table student-data-table hocvuot-action-table mb-0">
            <thead><tr><th>Môn học</th><th>Lớp học</th><th>Ngày đăng ký</th><th>Hạn thao tác</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
            <tbody>
            @if (Model.DangKyHocVuot.Count == 0)
            {
                <tr><td colspan="6"><div class="student-empty compact"><i class="bi bi-journal-check"></i><strong>Chưa có môn học vượt trong học kỳ này.</strong></div></td></tr>
            }
            else
            {
                @foreach (var item in Model.DangKyHocVuot)
                {
                    <tr>
                        <td><strong>@item.TenMonHoc</strong><small>@item.MaMonHoc - @item.SoTinChi tín chỉ</small></td>
                        <td><span class="class-code">@item.MaLop</span><small>@item.TenLop</small><small>@item.LichHocText</small></td>
                        <td>@item.NgayDangKy.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (item.HanHuyDangKy.HasValue)
                            {
                                <span>Đến @item.HanHuyDangKy.Value.ToString("dd/MM/yyyy")</span>
                                <small>@HanText(item)</small>
                            }
                            else
                            {
                                <span class="text-muted">Chưa xác định</span>
                            }
                            <div class="mt-1"><span class="badge @HanBadge(item)">@HanBadgeText(item)</span></div>
                        </td>
                        <td><span class="hocvuot-status-chip @TrangThaiBadge(item.TrangThai)">@TrangThaiText(item.TrangThai)</span></td>
                        <td>
                            @if (item.TrangThai == TrangThaiDangKy.DaHuy)
                            {
                                <button type="button" class="btn btn-sm btn-success" data-hocvuot-reregister data-id="@item.DangKyHocId" data-name="@item.MaLop" data-can-action="@item.ConDuocDangKyLai.ToString().ToLowerInvariant()" data-blocked-reason="@item.LyDoKhongTheDangKyLai" aria-disabled="@(!item.ConDuocDangKyLai).ToString().ToLowerInvariant()" title="@item.LyDoKhongTheDangKyLai">
                                    <i class="bi bi-arrow-repeat"></i> Đăng ký lại
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger" data-hocvuot-cancel data-id="@item.DangKyHocId" data-name="@item.MaLop" data-can-action="@item.ConDuocHuy.ToString().ToLowerInvariant()" data-blocked-reason="@item.LyDoKhongTheHuy" aria-disabled="@(!item.ConDuocHuy).ToString().ToLowerInvariant()" title="@item.LyDoKhongTheHuy">
                                    <i class="bi bi-x-circle"></i> Hủy đăng ký
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@functions {
    string TrangThaiText(TrangThaiDangKy value) => value switch
    {
        TrangThaiDangKy.ChoDuyet => "Chờ duyệt",
        TrangThaiDangKy.DaDuyet => "Đã duyệt",
        TrangThaiDangKy.DaDangKy => "Đã đăng ký",
        TrangThaiDangKy.TuChoi => "Từ chối",
        TrangThaiDangKy.DaHuy => "Đã hủy",
        _ => value.ToString()
    };

    string TrangThaiBadge(TrangThaiDangKy value) => value switch
    {
        TrangThaiDangKy.DaHuy => "is-cancelled",
        TrangThaiDangKy.DaDuyet or TrangThaiDangKy.DaDangKy => "is-approved",
        TrangThaiDangKy.ChoDuyet => "is-pending",
        TrangThaiDangKy.TuChoi => "is-rejected",
        _ => "is-muted"
    };

    string HanText(SinhVienHocVuotItemViewModel item)
    {
        if (!item.SoNgayConLai.HasValue) return "Không xác định ngày bắt đầu lớp.";
        if (item.SoNgayConLai.Value < 0) return "Đã quá thời hạn hủy/đăng ký lại.";
        if (item.SoNgayConLai.Value == 0) return "Hạn cuối hôm nay.";
        return $"Còn lại {item.SoNgayConLai.Value} ngày.";
    }

    string HanBadge(SinhVienHocVuotItemViewModel item)
    {
        if (item.TrangThai == TrangThaiDangKy.DaHuy) return "text-bg-secondary";
        if (!item.SoNgayConLai.HasValue || item.SoNgayConLai.Value < 0) return "text-bg-danger";
        if (item.SoNgayConLai.Value <= 3) return "text-bg-warning";
        return "text-bg-success";
    }

    string HanBadgeText(SinhVienHocVuotItemViewModel item)
    {
        if (item.TrangThai == TrangThaiDangKy.DaHuy) return "Đã hủy";
        if (!item.SoNgayConLai.HasValue || item.SoNgayConLai.Value < 0) return "Hết hạn";
        if (item.SoNgayConLai.Value <= 3) return "Sắp hết hạn";
        return "Còn hạn";
    }
}

@section Scripts {
    <script src="~/js/hocvuot.js" asp-append-version="true"></script>
}
